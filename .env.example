# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Shopify Admin API (required)
SHOPIFY_STORE_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# Agentway (optional — report degrades gracefully without it)
AGENTWAY_API_URL=https://api.agentway.com
AGENTWAY_API_KEY=...

# Email via Resend (optional — falls back to local file)
RESEND_API_KEY=re_...
REPORT_RECIPIENTS=ceo@company.com
REPORT_FROM_EMAIL=insights@yourdomain.com

# Scheduler (optional — defaults to Monday 7am)
REPORT_SCHEDULE_DAY=mon
REPORT_SCHEDULE_HOUR=7
REPORT_SCHEDULE_MINUTE=0

# Data lookback (optional — defaults to 90 days)
DEFAULT_LOOKBACK_DAYS=90

# Server (optional)
PORT=8000
